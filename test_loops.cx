// Test loops and control flow
void main() {
    println("=== Loops and Control Flow ===");
    
    // Test for loop
    println("For loop:");
    for (int i = 0; i < 5; i++) {
        printf("  i=%d\n", i);
    }
    
    // Test while loop
    println("While loop:");
    int j = 0;
    while (j < 3) {
        printf("  j=%d\n", j);
        j++;
    }
    
    // Test break and continue
    println("Break/continue:");
    for (int k = 0; k < 10; k++) {
        if (k == 2) continue;
        if (k == 5) break;
        printf("  k=%d\n", k);
    }
    
    println("=== Done ===");
}
