// Test edge cases
void main() {
    // Test empty optional check
    int? empty;
    if (!empty?) {
        println("empty optional check works");
    }
    
    // Test match with multiple conditions
    int val = 5;
    string res = match val {
        1 => "one",
        2 => "two",
        3 => "three",
        4 => "four",
        5 => "five",
        _ => "other"
    };
    printf("match 5 => %s\n", res);
    
    // Test 2D array
    int[][] matrix = {{1,2,3}, {4,5,6}, {7,8,9}};
    printf("matrix[0][0]=%d, matrix[1][1]=%d\n", matrix[0][0], matrix[1][1]);
    
    println("All edge cases passed!");
}
