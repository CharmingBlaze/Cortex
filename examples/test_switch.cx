// Test switch and select case

enum Status { Pending, Active, Done, Failed }

void main() {
    println("=== Switch Test ===");
    
    Status s = Active;
    
    switch (s) {
        case Pending:
            println("Status: Pending");
            break;
        case Active:
            println("Status: Active");
            break;
        case Done:
            println("Status: Done");
            break;
        default:
            println("Status: Unknown");
    }
    
    println("");
    println("=== SELECT CASE Test ===");
    
    int level = 5;
    
    SELECT CASE level
        CASE 1 TO 5
            println("Low level");
        CASE 6 TO 10
            println("Mid level");
        CASE ELSE
            println("High level");
    END SELECT
}
