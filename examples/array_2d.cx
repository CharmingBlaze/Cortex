// Array example - basic array operations
void main() {
    // Create arrays
    int row0[2];
    row0[0] = 1;
    row0[1] = 2;
    
    int row1[2];
    row1[0] = 3;
    row1[1] = 4;
    
    println("row0[0] = " + row0[0]);
    println("row0[1] = " + row0[1]);
    println("row1[0] = " + row1[0]);
    println("row1[1] = " + row1[1]);
    
    // Modify element
    row0[1] = 99;
    println("row0[1] after modification = " + row0[1]);
    
    waitkey();
}
