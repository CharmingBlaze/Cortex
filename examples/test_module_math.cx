// Math Module Test - tests math helper functions

int math_add(int a, int b) {
    return a + b;
}

int math_mul(int a, int b) {
    return a * b;
}

void main() {
    println("=== Math Module Test ===");
    
    int sum = math_add(10, 20);
    int product = math_mul(5, 6);
    
    println("Testing math_add(10, 20) = " + sum);
    println("Testing math_mul(5, 6) = " + product);
    
    if (sum == 30 && product == 30) {
        println("All tests PASSED!");
    } else {
        println("Tests FAILED!");
    }
    
    println("=== Test completed! ===");
}
